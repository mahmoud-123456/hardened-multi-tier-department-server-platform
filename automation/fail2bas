#!/bin/bash
sudo apt update
sudo apt install apache2 mysql-server fail2ban -y
sudo systemctl start apache2
sudo systemctl start mysql
sudo systemctl start fail2ban
sudo systemctl enable apache2
sudo systemctl enable mysql
sudo systemctl enable fail2ban
sudo mkdir -p /var/www/helpdesk
echo "<h1>Helpdesk Portal</h1>" | sudo tee /var/www/helpdesk/index.html
sudo mysql -u root -e "CREATE DATABASE IF NOT EXISTS helpdesk;"
sudo mysql -u root -e "CREATE TABLE IF NOT EXISTS helpdesk.tickets (id INT AUTO_INCREMENT PRIMARY KEY, title VARCHAR(255));"
sudo mysql -u root -e "INSERT INTO helpdesk.tickets (title) VALUES ('Test Ticket 1'), ('Test Ticket 2');"
mkdir -p ~/helpdesk-security-project
cd ~/helpdesk-security-project
cat > daily_backup.sh << 'EOF'
#!/bin/bash
BACKUP_DIR="/backups"
DATE=$(date +%Y%m%d_%H%M%S)
DB_NAME="helpdesk"
DB_USER="root"
DB_PASS=""
WEB_ROOT="/var/www/helpdesk"
sudo mkdir -p $BACKUP_DIR
sudo mysqldump -u $DB_USER $DB_NAME > $BACKUP_DIR/db_$DATE.sql
sudo tar -czf $BACKUP_DIR/web_$DATE.tar.gz $WEB_ROOT
sudo find $BACKUP_DIR -type f -mtime +7 -delete
echo "Backup completed at $DATE"
EOF
cat > health_check.sh << 'EOF'
#!/bin/bash
SERVICES=("ssh" "apache2" "mysql")
WEB_URL="http://localhost"
for service in "${SERVICES[@]}"; do
    if sudo systemctl is-active --quiet $service; then
        echo "$service is UP"
    else
        echo "$service is DOWN! Attempting restart..."
        sudo systemctl restart $service
        echo "$service restarted at $(date)" | sudo tee -a /var/log/health_check.log
    fi
done
if curl -f -s -I "$WEB_URL" > /dev/null; then
    echo "Web portal is UP"
else
    echo "Web portal is unreachable! Restarting web server..."
    sudo systemctl restart apache2
    echo "Web server restarted at $(date)" | sudo tee -a /var/log/health_check.log
fi
EOF
cat > restore_latest.sh << 'EOF'
#!/bin/bash
BACKUP_DIR="/backups"
DB_NAME="helpdesk"
DB_USER="root"
DB_PASS=""
LATEST_DB=$(ls -t $BACKUP_DIR/db_*.sql 2>/dev/null | head -n1)
if [ -z "$LATEST_DB" ]; then
    echo "No database backup found!"
    exit 1
fi
sudo mysql -u $DB_USER $DB_NAME < $LATEST_DB
if [ $? -eq 0 ]; then
    echo "Database restored successfully from: $LATEST_DB"
else
    echo "Restore failed!"
    exit 1
fi
EOF
chmod +x daily_backup.sh health_check.sh restore_latest.sh
sudo cat > /etc/fail2ban/jail.local << 'EOF'
[DEFAULT]
bantime = 600
findtime = 600
maxretry = 5
[sshd]
enabled = true
port = ssh
filter = sshd
logpath = /var/log/auth.log
maxretry = 3
bantime = 3600
[apache-auth]
enabled = true
port = http,https
filter = apache-auth
logpath = /var/log/apache2/error.log
maxretry = 5
[apache-badbots]
enabled = true
port = http,https
filter = apache-badbots
logpath = /var/log/apache2/access.log
maxretry = 2
EOF
sudo systemctl restart fail2ban
( sudo crontab -l 2>/dev/null; echo "0 2 * * * $HOME/helpdesk-security-project/daily_backup.sh" ) | sudo crontab -
( sudo crontab -l 2>/dev/null; echo "*/5 * * * * $HOME/helpdesk-security-project/health_check.sh" ) | sudo crontab -
